<%- include('partials/header') %>
<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card p-4">
            <h4>Edit Category</h4>
            <form action="/categories/edit/<%= category.id %>" method="POST">
                <div class="mb-3">
                    <label class="form-label">Category Name</label>
                    <input type="text" name="categoryName" class="form-control" value="<%= category.name %>" required>
                </div>
                <button type="submit" class="btn btn-warning w-100">Update Category</button>
                <a href="/categories" class="btn btn-secondary w-100 mt-2">Cancel</a>
            </form>
        </div>
    </div>
</div>
</body>
</html>