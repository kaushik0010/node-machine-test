<%- include('partials/header') %>
<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card p-4">
            <h4>Edit Product</h4>
            <form action="/products/edit/<%= product.id %>" method="POST">
                <div class="mb-3">
                    <label class="form-label">Product Name</label>
                    <input type="text" name="productName" class="form-control" value="<%= product.name %>" required>
                </div>
                
                <div class="mb-3">
                    <label class="form-label">Category</label>
                    <select name="categoryId" class="form-select" required>
                        <% categories.forEach(cat => { %>
                            <option value="<%= cat.id %>" <%= product.category_id === cat.id ? 'selected' : '' %>>
                                <%= cat.name %>
                            </option>
                        <% }) %>
                    </select>
                </div>
                
                <button type="submit" class="btn btn-warning w-100">Update Product</button>
                <a href="/products" class="btn btn-secondary w-100 mt-2">Cancel</a>
            </form>
        </div>
    </div>
</div>
</body>
</html>